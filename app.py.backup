                            scale=3
                        )
                        search_btn = gr.Button("🔍 Search", size="sm", scale=1)

                    prompt_history_dropdown = gr.Dropdown(
                        label="Recent Prompts",
                        choices=prompt_history.get_dropdown_choices(),
                        value=None,
                        interactive=True,
                        allow_custom_value=False
                    )

                    with gr.Row():
                        load_prompt_btn = gr.Button("📥 Load Selected", size="sm")
                        refresh_history_btn = gr.Button("🔄 Refresh", size="sm")

                    with gr.Row():
                        export_prompts_btn = gr.Button("💾 Export History", size="sm")
                        import_file = gr.File(
                            label="Import History",
                            file_types=[".json"],
                            type="filepath"
                        )

                    history_status = gr.Textbox(
                        label="Status",
                        value="",
                        interactive=False,
                        visible=False
                    )

                # Generation Presets
                with gr.Row():
                    gr.Markdown("**Quick Presets:**")
                with gr.Row():
                    preset_fast = gr.Button("⚡ Fast Draft", size="sm")
                    preset_balanced = gr.Button("⚖️ Balanced", size="sm")
                    preset_quality = gr.Button("✨ High Quality", size="sm")
                    preset_ultra = gr.Button("🔥 Ultra Detail", size="sm")

                # Generation Settings
                with gr.Accordion("⚙️ Generation Settings", open=False):
                    with gr.Row():
                        steps_slider = gr.Slider(
                            minimum=4, maximum=50, value=DEFAULT_STEPS, step=1,
                            label="Steps (20 recommended for Krea)"
                        )

                    with gr.Row():
                        width_slider = gr.Slider(
                            minimum=512, maximum=2048, value=DEFAULT_WIDTH, step=64,
                            label="Width"
                        )
                        height_slider = gr.Slider(
                            minimum=512, maximum=2048, value=DEFAULT_HEIGHT, step=64,
                            label="Height"
                        )

                    # Seed Management Section
                    gr.Markdown("**Seed Management:**")

                    with gr.Row():
                        seed_input = gr.Textbox(
                            label="Seed",
                            placeholder="Leave empty for random",
                            value="",
                            scale=2
                        )
                        seed_lock_checkbox = gr.Checkbox(
                            label="🔒 Lock",
                            value=False,
                            info="Keep using this seed",
                            scale=1
                        )

                    with gr.Row():
                        use_last_seed_btn = gr.Button("🔄 Last", size="sm")
                        seed_minus_100_btn = gr.Button("-100", size="sm")
                        seed_minus_10_btn = gr.Button("-10", size="sm")
                        seed_minus_1_btn = gr.Button("-1", size="sm")
                        seed_plus_1_btn = gr.Button("+1", size="sm")
                        seed_plus_10_btn = gr.Button("+10", size="sm")
                        seed_plus_100_btn = gr.Button("+100", size="sm")
                        seed_random_btn = gr.Button("🎲 Random", size="sm")

                    with gr.Row():
                        seed_history_dropdown = gr.Dropdown(
                            label="Seed History",
