    logger.info(f"Vision Chat Model: {OLLAMA_VISION_MODEL}")
    logger.info(f"FLUX Finetune: {FINETUNE_NAME}")
    logger.info("=" * 60)
    logger.info("")
    logger.info("Access URLs:")
